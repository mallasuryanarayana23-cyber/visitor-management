{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=your_postgres_server.render.com;Database=your_db_name;Username=your_username;Password=your_password;Port=5432;"
  },
  "AppSettings": {
    "UploadServerPath": "/app/uploads",
    "UploadBaseUrl": "/uploads",
    "MaxPhotoSizeMB": "2",
    "MaxDocSizeMB": "5",
    "AllowedImageExt": ".jpg,.jpeg,.png",
    "AllowedDocExt": ".pdf,.jpg,.jpeg,.png"
  }
}
