{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=your_render_postgres_host;Database=vmsdb;Username=your_user;Password=your_password;SSL Mode=Require",
    "OracleVMS": "Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=your_host)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=your_service)));User Id=your_user;Password=your_password;"
  },
  "AppSettings": {
    "UploadServerPath": "/app/uploads",
    "UploadBaseUrl": "/uploads",
    "MaxPhotoSizeMB": "2",
    "MaxDocSizeMB": "5",
    "AllowedImageExt": ".jpg,.jpeg,.png",
    "AllowedDocExt": ".pdf,.jpg,.jpeg,.png"
  }
}
