<?xml version="1.0" encoding="utf-8"?>
<!-- For more information on using web.config transformation visit https://go.microsoft.com/fwlink/?LinkId=125889 -->
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  
  <connectionStrings>
    <!-- 
      This is where we replace the local database connection with the cloud (production) database connection.
      Make sure to fill in your actual production Host, Username, and Password before or during deployment.
    -->
    <add name="OracleVMS" 
         connectionString="Data Source=//PRODUCTION_SERVER:1521/ORCL;User Id=PROD_USER;Password=YOUR_PROD_PASSWORD;" 
         xdt:Transform="SetAttributes" xdt:Locator="Match(name)"/>
  </connectionStrings>

  <system.web>
    <!-- Removes the 'debug' flag which should NEVER be true in production -->
    <compilation xdt:Transform="RemoveAttributes(debug)" />
  </system.web>

</configuration>
