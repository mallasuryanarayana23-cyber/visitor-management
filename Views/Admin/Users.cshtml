@{
    ViewBag.Title = "System Users";
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 text-dark">Staff & Users</h5>
        <div>
            <button class="btn btn-primary btn-sm me-2" id="guardPasswordBtn">🔐 Guard Password Setup</button>
            <button class="btn btn-success btn-sm" id="addUserBtn">+ Add New User</button>
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle" id="usersTable">
                <thead class="table-light">
                    <tr>
                        <th>Employee ID / Guard No.</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="usersTableBody">
                    <!-- Loaded dynamically via AJAX -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add / Edit User Modal -->
<div class="modal fade" id="userModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="userModalTitle">Add New User</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="userForm" novalidate>
                    <input type="hidden" id="editUserId" />
                    <input type="hidden" id="isEditMode" value="false" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Employee ID / Guard No. <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="userEmpId" name="username" placeholder="e.g. GUARD002 or EMP500" required />
                        <div class="invalid-feedback">Employee ID is required.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="userName" name="name" placeholder="e.g. John Smith" required />
                        <div class="invalid-feedback">Name is required.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email Address <span class="text-danger">*</span></label>
                        <input type="email" class="form-control" id="userEmail" placeholder="e.g. john@vms.com" required />
                        <div class="invalid-feedback">Valid email is required.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Role <span class="text-danger">*</span></label>
                        <select class="form-select" id="userRole" name="role" required>
                            <option value="">-- Select Role --</option>
                            <option value="Admin">Administrator</option>
                            <option value="Guard">Security Guard</option>
                            <option value="User">Host Employee</option>
                        </select>
                        <div class="invalid-feedback">Please select a role.</div>
                    </div>
                    <div id="passwordSection" class="mb-3">
                        <label class="form-label fw-semibold">Initial Password <span class="text-danger">*</span></label>
                        <input type="password" class="form-control" id="userPassword" name="password" placeholder="Minimum 8 characters" />
                        <div class="invalid-feedback">Password is required (min 8 chars).</div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-success" id="saveUserBtn">💾 Save User</button>
            </div>
        </div>
    </div>
</div>

<!-- Reset Password Modal -->
<div class="modal fade" id="resetModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title">Reset Password</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Set new password for <strong id="resetUserName"></strong>:</p>
                <input type="password" class="form-control" id="newPassword" placeholder="New password (min 8 chars)" />
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-warning btn-sm" id="confirmResetBtn">Reset</button>
            </div>
        </div>
    </div>
</div>

<!-- Guard Password Setup Modal -->
<div class="modal fade" id="guardPasswordModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Guard Password Setup</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="guardPasswordForm" novalidate>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Employee No <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="guardEmpNo" placeholder="Enter Guard Emp No" required />
                        <div class="invalid-feedback">Employee No is required.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">New Password <span class="text-danger">*</span></label>
                        <input type="password" class="form-control" id="guardNewPassword" placeholder="Minimum 8 characters" required />
                        <div class="invalid-feedback">Valid password required (min 8).</div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary btn-sm" id="saveGuardPasswordBtn">Set Password</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var roleBadge = {
            'ADMIN': '<span class="badge bg-danger">Administrator</span>',
            'GUARD': '<span class="badge bg-success">Security Guard</span>',
            'USER':  '<span class="badge bg-primary">Host Employee</span>'
        };

        $(document).ready(function () {
            loadUsers();

            // ---- Load Users via AJAX ----
            function loadUsers() {
                $.get('/Admin/GetUsersList', function (data) {
                    var html = '';
                    data.forEach(function (u) {
                        html += '<tr data-id="' + u.username + '">' +
                            '<td>' + u.username + '</td>' +
                            '<td>' + u.fullName + '</td>' +
                            '<td>' + (u.email || "-") + '</td>' +
                            '<td>' + (roleBadge[u.role] || u.role) + '</td>' +
                            '<td>' + (u.isActive == 1 ? '<span class="text-success fw-bold">● Active</span>' : '<span class="text-danger fw-bold">● Inactive</span>') + '</td>' +
                            '<td>' +
                                '<button class="btn btn-sm btn-outline-dark edit-user-btn" data-id="' + u.username + '" data-name="' + u.fullName + '" data-role="' + u.role + '">Edit</button> ' +
                                '<button class="btn btn-sm ' + (u.isActive == 1 ? 'btn-outline-secondary' : 'btn-outline-success') + ' toggle-status-btn" data-status="' + (u.isActive == 1 ? 'active' : 'inactive') + '">' + (u.isActive == 1 ? 'Deactivate' : 'Activate') + '</button>' +
                            '</td>' +
                            '</tr>';
                    });
                    $('#usersTableBody').html(html);
                    if ($.fn.DataTable.isDataTable('#usersTable')) {
                        $('#usersTable').DataTable().destroy();
                    }
                    $('#usersTable').DataTable({ "pageLength": 10 });
                });
            }

            // ---- Open ADD modal ----
            $('#addUserBtn').click(function () {
                $('#userModalTitle').text('Add New User');
                $('#userForm')[0].reset();
                $('#userEmpId').prop('readonly', false);
                $('#userForm .is-invalid').removeClass('is-invalid');
                $('#isEditMode').val('false');
                $('#passwordSection').show();
                new bootstrap.Modal(document.getElementById('userModal')).show();
            });

            // ---- Open EDIT modal ----
            $(document).on('click', '.edit-user-btn', function () {
                $('#userModalTitle').text('Edit User');
                $('#isEditMode').val('true');
                $('#userEmpId').val($(this).data('id')).prop('readonly', true);
                var fullName = $(this).data('name');
                var role = $(this).data('role');
                
                $('#userName').val(fullName);
                $('#userRole').val(role.charAt(0).toUpperCase() + role.slice(1).toLowerCase());
                
                $('#passwordSection').hide();
                $('#userForm .is-invalid').removeClass('is-invalid');
                new bootstrap.Modal(document.getElementById('userModal')).show();
            });

            // ---- Save User (Add or Edit) ----
            $('#saveUserBtn').click(function () {
                var empId = $('#userEmpId').val().trim();
                var name  = $('#userName').val().trim();
                var role  = $('#userRole').val();
                var pass  = $('#userPassword').val().trim();
                var isEdit = $('#isEditMode').val() === 'true';

                if (!empId || !name || !role || (!isEdit && pass.length < 8)) {
                    toastr.error('Please fill all required fields correctly.');
                    return;
                }

                $(this).html('<span class="spinner-border spinner-border-sm"></span> Saving...').prop('disabled', true);
                
                $.post('/Admin/SaveUser', {
                    username: empId,
                    name: name,
                    role: role,
                    password: pass,
                    isEdit: isEdit
                }, function(res) {
                    $('#saveUserBtn').html('💾 Save User').prop('disabled', false);
                    if (res.success) {
                        bootstrap.Modal.getInstance(document.getElementById('userModal')).hide();
                        toastr.success(res.message);
                        loadUsers();
                    } else {
                        toastr.error(res.message);
                    }
                });
            });

            // ---- Toggle Status ----
            $(document).on('click', '.toggle-status-btn', function () {
                var btn = $(this);
                var username = btn.closest('tr').data('id');
                var isCurrentlyActive = btn.data('status') === 'active';

                $.post('/Admin/ToggleUserStatus', { username: username, active: !isCurrentlyActive }, function(res) {
                    if (res.success) {
                        toastr.success('Status updated!');
                        loadUsers();
                    } else {
                        toastr.error(res.message);
                    }
                });
            });

            // ---- Guard Password Setup (Existing) ----
            $('#guardPasswordBtn').click(function () {
                $('#guardPasswordForm')[0].reset();
                new bootstrap.Modal(document.getElementById('guardPasswordModal')).show();
            });

            $('#saveGuardPasswordBtn').click(function () {
                var empNo = $('#guardEmpNo').val().trim();
                var pw = $('#guardNewPassword').val().trim();
                if (!empNo || pw.length < 8) return;

                $.post('/Admin/SetGuardPassword', { empNo: empNo, password: pw }, function(res) {
                    if (res.success) {
                        bootstrap.Modal.getInstance(document.getElementById('guardPasswordModal')).hide();
                        toastr.success(res.message);
                    } else {
                        toastr.error(res.message);
                    }
                });
            });
        });
    </script>
}
