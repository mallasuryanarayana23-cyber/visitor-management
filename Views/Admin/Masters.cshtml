@{
    ViewBag.Title = "Master Data Settings";
}

<div class="row">
    <!-- Departments -->
    <div class="col-md-6 mb-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white py-3 d-flex justify-content-between">
                <h6 class="mb-0">🏢 Departments</h6>
                <button class="btn btn-sm btn-outline-primary"><i class="bi bi-plus"></i> Add</button>
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    Engineering
                    <span class="badge bg-secondary rounded-pill">14 Hosts</span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    Human Resources
                    <span class="badge bg-secondary rounded-pill">3 Hosts</span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    Executive
                    <span class="badge bg-secondary rounded-pill">5 Hosts</span>
                </li>
            </ul>
        </div>
    </div>
    
    <!-- Meeting Purposes -->
    <div class="col-md-6 mb-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white py-3 d-flex justify-content-between">
                <h6 class="mb-0">🎯 Meeting Purposes</h6>
                <button class="btn btn-sm btn-outline-primary"><i class="bi bi-plus"></i> Add</button>
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item">Business Meeting</li>
                <li class="list-group-item">Interview</li>
                <li class="list-group-item">Vendor/Delivery</li>
                <li class="list-group-item">Personal</li>
            </ul>
        </div>
    </div>
</div>
