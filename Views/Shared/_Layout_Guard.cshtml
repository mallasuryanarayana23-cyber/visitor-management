<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Guard | VMS</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Toastr -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <!-- DataTables -->
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
    <style>
        .sidebar-green {
            background-color: #198754;
            min-height: 100vh;
            color: white;
        }
        .sidebar-green a {
            color: #d1e7dd;
            text-decoration: none;
            padding: 10px 15px;
            display: block;
        }
        .sidebar-green a:hover {
            background-color: #157347;
            color: white;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-2 d-none d-md-block sidebar-green shadow">
                <div class="position-sticky pt-3">
                    <h4 class="px-3 pb-3 border-bottom text-white">VMS Guard Post</h4>
                    <ul class="nav flex-column mt-3">
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Dashboard", "Guard")">
                                📊 Dashboard
                            </a>
                        </li>
                        <li class="nav-item mt-2">
                            <a class="nav-link" href="@Url.Action("Search", "Guard")">
                                🔍 Search Visitor
                            </a>
                        </li>
                        <li class="nav-item mt-2">
                            <a class="nav-link" href="@Url.Action("TodayList", "Guard")">
                                📋 Today's List
                            </a>
                        </li>
                        <li class="nav-item mt-5 pt-3 border-top">
                            <a class="nav-link text-warning" href="@Url.Action("Logout", "Account")">
                                🚪 Logout
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>

            <main class="col-md-10 ms-sm-auto px-md-4 py-4">
                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-3 border-bottom">
                    <h1 class="h2 text-success">@ViewBag.Title</h1>
                </div>

                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Modal Lightbox inside layout for global access -->
    <div class="modal fade" id="imageLightboxModal" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content border-0 bg-transparent">
                <div class="modal-body text-center p-0 position-relative">
                    <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" style="z-index: 1050;"></button>
                    <img id="lightboxImg" src="" class="img-fluid rounded shadow-lg" style="max-height: 90vh;" />
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script>
        function openLightbox(url) {
            $('#lightboxImg').attr('src', url);
            var myModal = new bootstrap.Modal(document.getElementById('imageLightboxModal'));
            myModal.show();
        }
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
