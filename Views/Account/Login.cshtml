@model VMS.Models.LoginViewModel

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | Visitor Management System</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        * { font-family: 'Inter', sans-serif; }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 50%, #1e40af 100%);
            display: flex; align-items: center; justify-content: center;
            padding: 20px;
        }

        /* animated background orbs */
        body::before, body::after {
            content: '';
            position: fixed;
            border-radius: 50%;
            filter: blur(80px);
            opacity: .25;
            z-index: 0;
        }
        body::before {
            width: 400px; height: 400px;
            background: #3b82f6;
            top: -100px; left: -100px;
            animation: float 8s ease-in-out infinite;
        }
        body::after {
            width: 350px; height: 350px;
            background: #8b5cf6;
            bottom: -100px; right: -100px;
            animation: float 10s ease-in-out infinite reverse;
        }
        /* CSS Animation */
        @@keyframes float {
            0%, 100% { transform: translate(0, 0); }
            50%       { transform: translate(30px, 30px); }
        }

        .login-wrapper {
            position: relative; z-index: 1;
            width: 100%; max-width: 440px;
        }

        .login-card {
            background: rgba(255,255,255,.97);
            border-radius: 24px;
            padding: 44px 40px;
            box-shadow: 0 25px 60px rgba(0,0,0,.35);
        }

        .brand-logo {
            width: 60px; height: 60px;
            background: linear-gradient(135deg, #1e3a8a, #3b82f6);
            border-radius: 16px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.7rem; margin: 0 auto 16px;
            box-shadow: 0 8px 20px rgba(59,130,246,.4);
        }

        .form-control {
            border-radius: 10px;
            padding: 12px 16px;
            border: 1.5px solid #e2e8f0;
            font-size: .95rem;
            transition: border-color .2s, box-shadow .2s;
        }
        .form-control:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 4px rgba(59,130,246,.12);
        }

        .form-label { font-weight: 600; font-size: .875rem; color: #374151; margin-bottom: 6px; }

        .input-group-text {
            border-radius: 10px 0 0 10px;
            background: #f8fafc;
            border: 1.5px solid #e2e8f0;
            border-right: none;
            color: #64748b;
        }
        .input-group .form-control { border-radius: 0 10px 10px 0; border-left: none; }
        .input-group:focus-within .input-group-text { border-color: #3b82f6; }

        .btn-login {
            background: linear-gradient(135deg, #1e3a8a, #3b82f6);
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 700;
            font-size: 1rem;
            letter-spacing: .3px;
            transition: transform .15s, box-shadow .15s;
            box-shadow: 0 4px 15px rgba(59,130,246,.4);
        }
        .btn-login:hover { transform: translateY(-1px); box-shadow: 0 8px 25px rgba(59,130,246,.5); }
        .btn-login:active { transform: translateY(0); }

        .role-badge {
            display: inline-block;
            padding: 4px 12px; border-radius: 20px;
            font-size: .75rem; font-weight: 600;
            cursor: pointer; transition: all .15s;
            border: 1.5px solid transparent;
        }
        .role-badge:hover { transform: scale(1.05); }
        .badge-admin  { background: #fef2f2; color: #dc2626; border-color: #fecaca; }
        .badge-guard  { background: #f0fdf4; color: #16a34a; border-color: #bbf7d0; }
        .badge-user   { background: #eff6ff; color: #2563eb; border-color: #bfdbfe; }

        .divider { position: relative; text-align: center; margin: 20px 0; }
        .divider::before {
            content: '';
            position: absolute; top: 50%; left: 0; right: 0;
            border-top: 1px solid #e2e8f0;
        }
        .divider span {
            position: relative; background: white;
            padding: 0 12px; font-size: .8rem; color: #94a3b8;
        }

        .show-pw-btn {
            position: absolute; right: 14px; top: 50%;
            transform: translateY(-50%);
            background: none; border: none; color: #94a3b8;
            cursor: pointer; padding: 0; font-size: 1rem;
        }
        .pw-wrap { position: relative; }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-card">

            <!-- Brand -->
            <div class="text-center mb-4">
                <div class="brand-logo">🏢</div>
                <h4 class="fw-bold text-dark mb-1">Visitor Management System</h4>
                <p class="text-muted small mb-0">Sign in with your Employee ID</p>
            </div>

            <!-- Error Alert -->
            @if (ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
            {
                <div class="alert alert-danger py-2 rounded-3 small mb-3">
                    <strong>❌</strong>
                    @Html.ValidationSummary(true, "", new { @class = "m-0 list-unstyled d-inline" })
                </div>
            }

            <!-- Login Form -->
            @using (Html.BeginForm("Login", "Account", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">Employee ID</label>
                    <div class="input-group">
                        <span class="input-group-text">🪪</span>
                        @Html.TextBoxFor(m => m.Username, new {
                            @class = "form-control",
                            placeholder = "e.g. EMP001",
                            autocomplete = "username",
                            required = "required"
                        })
                    </div>
                    @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger small" })
                </div>

                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <div class="pw-wrap">
                        <div class="input-group">
                            <span class="input-group-text">🔒</span>
                            @Html.PasswordFor(m => m.Password, new {
                                @class = "form-control",
                                placeholder = "Enter your password",
                                id = "passwordInput",
                                autocomplete = "current-password",
                                required = "required"
                            })
                        </div>
                        <button type="button" class="show-pw-btn" id="togglePw" title="Show/Hide password" style="right:16px">👁</button>
                    </div>
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                </div>

                <button type="submit" class="btn btn-login text-white w-100">
                    Sign In →
                </button>
            }

            <!-- Quick Login Hint -->
            <div class="divider mt-4"><span>Role Credentials</span></div>
            <div class="d-flex justify-content-center gap-2 flex-wrap">
                <span class="role-badge badge-admin" onclick="fillLogin('ADMIN001','Admin@123')" title="Click to fill">
                    🔴 Admin — ADMIN001
                </span>
                <span class="role-badge badge-guard" onclick="fillLogin('GUARD001','Guard@123')" title="Click to fill">
                    🟢 Guard — GUARD001
                </span>
                <span class="role-badge badge-user" onclick="fillLogin('EMP001','User@123')" title="Click to fill">
                    🔵 User — EMP001
                </span>
            </div>
            <p class="text-center text-muted mt-3 mb-0" style="font-size:.75rem;">
                Click any role badge above to auto-fill credentials
            </p>
        </div>

        <p class="text-center text-white-50 mt-3 small">
            © 2026 Visitor Management System. All rights reserved.
        </p>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script>
        // Toggle password visibility
        document.getElementById('togglePw').addEventListener('click', function () {
            var inp = document.getElementById('passwordInput');
            inp.type = inp.type === 'password' ? 'text' : 'password';
            this.textContent = inp.type === 'password' ? '👁' : '🙈';
        });

        // Auto-fill credentials from role badges
        function fillLogin(empId, password) {
            var usernameInput = document.querySelector('input[name="Username"]') ||
                                document.querySelector('input[id$="Username"]') ||
                                document.querySelector('input[placeholder="e.g. EMP001"]');
            var passwordInput = document.getElementById('passwordInput');
            if (usernameInput) usernameInput.value = empId;
            if (passwordInput) passwordInput.value = password;
        }
    </script>
</body>
</html>
