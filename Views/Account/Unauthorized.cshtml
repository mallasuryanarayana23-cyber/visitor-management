@{
    ViewBag.Title = "Unauthorized Access";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Unauthorized - VMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-sm p-5 text-center">
        <h1 class="text-danger display-1">403</h1>
        <h2>Access Denied</h2>
        <p>You do not have permission to access the requested role dashboard or action.</p>
        <a href="@Url.Action("Login", "Account")" class="btn btn-primary mt-3">Return to Login</a>
    </div>
</body>
</html>
